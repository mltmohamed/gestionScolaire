{
  "appId": "com.schoolmanage.app",
  "productName": "SchoolManage",
  "directories": {
    "output": "release"
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "package.json"
  ],
  "win": {
    "target": ["nsis", "portable"],
    "sign": null,
    "signDlls": false,
    "signAndEditExecutable": false
  },
  "mac": {
    "target": ["dmg"],
    "icon": "src/resources/icons/icon.icns"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "src/resources/icons/icon.png"
  }
}
